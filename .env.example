# API Configuration (Production)
VITE_API_URL=https://api.stonkmarket.xyz/api
VITE_AUTH_URL=https://api.stonkmarket.xyz
# Must use /ws path — production ingress routes WebSocket at /ws
VITE_WEBSOCKET_URL=wss://api.stonkmarket.xyz/ws

# Smart Contracts (Base Sepolia Testnet)
VITE_BASE_VAULT_ADDRESS=0xeb3b769e24F003Af0A1B869aeCfeD87154758868
VITE_EVM_TOKEN_FACTORY_ADDRESS=0x54c1531CD546220E0725D5dbBa27b9C4b11B567F
VITE_EVM_ROUTER_ADDRESS=0xEeDE62252b4675A2cB2C4A5703de27aBb5607aE3
VITE_EVILWETH_ADDRESS=0xb6fA8070eba82cB11d6E559FD03c966781Ee34d7

# External Services
# Get your WalletConnect Project ID at: https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Configuration
VITE_DEPLOYMENT_FEE_ETH=0.0

# Error Reporting (Optional)
# Get your Sentry DSN at: https://sentry.io/
# Format: https://<key>@<organization>.ingest.sentry.io/<project>
# VITE_ERROR_REPORTING_URL=your_sentry_dsn_here

# Development URLs
# For local development, copy .env.development which includes:
# VITE_API_URL=http://localhost:3000/api
# VITE_AUTH_URL=http://localhost:8080  (uses Vite proxy - see vite.config.ts)
# VITE_WEBSOCKET_URL=ws://localhost:3001
#
# The Vite proxy ensures cookies work correctly by making auth requests
# appear same-origin (localhost:8080 → localhost:3001 proxied)
